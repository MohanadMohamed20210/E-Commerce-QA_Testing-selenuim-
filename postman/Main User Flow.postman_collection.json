    {
      "name": "Checkout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let body = pm.response.json();\r",
              "\r",
              "pm.test(\"check status code\", function () {\r",
              "    pm.expect(pm.response.code).to.be.eql(200);\r",
              "    pm.expect(pm.response.status).to.be.eq(\"OK\")\r",
              "});\r",
              "\r",
              "pm.test(\"check response time\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "let expectedSchima = {\r",
              "    message: {\r",
              "        type: \"string\"\r",
              "    },\r",
              "    order: {\r",
              "        type: \"object\",\r",
              "        required: [\"orderId\", \"total\"],\r",
              "        properties: {\r",
              "            orderId: {\r",
              "                type: \"number\"\r",
              "            },\r",
              "            total: {\r",
              "                type: \"number\"\r",
              "            }\r",
              "        }\r",
              "    }\r",
              "}\r",
              "\r",
              "//{\"message\":\"Order created\",\"order\":{\"orderId\":1,\"total\":18.75}}\r",
              "pm.test(\"recieved data\", function () {\r",
              "    pm.response.to.have.jsonSchema(expectedSchima);\r",
              "    pm.expect(body.message).to.eql(\"Order created\");\r",
              "    pm.expect(body.order.orderId).to.be.a(\"number\");\r",
              "    pm.expect(body.order.total).to.be.a(\"number\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
