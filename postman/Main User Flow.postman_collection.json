    {
      "name": "Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "let body = pm.response.json();\r",
              "\r",
              "pm.test(\"check status code\", function () {\r",
              "    pm.expect(pm.response.code).to.be.eql(201);\r",
              "    pm.expect(pm.response.status).to.be.eq(\"Created\")\r",
              "});\r",
              "\r",
              "pm.test(\"check response time\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"check the response body\", function () {\r",
              "    pm.expect(body.message).to.include(\"Registration successful\");\r",
              "    pm.expect(body.user.id).to.exist;\r",
              "    pm.expect(body.user.name).to.include(pm.environment.get(\"Name\"));\r",
              "    pm.expect(body.user.role).to.include(\"customer\");\r",
              "    pm.expect(body.user.status).to.include(\"active\");\r",
              "});\r",
              "\r",
              "pm.environment.set(\"Email\", body.user.email);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let body = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "pm.environment.set(\"Counter\", Number(pm.environment.get(\"Counter\") + 1));\r",
              "\r",
              "let newEmail = \"base\" + pm.environment.get(\"Counter\") + \"@gmail.com\";\r",
              "\r",
              "body[\"email\"] = newEmail;\r",
              "\r",
              "pm.request.body.update(JSON.stringify(body));\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":     \"{{Name}}\",\r\n    \"password\": \"{{Pass}}\",\r\n    \"phone\":    \"{{Phone}}\",\r\n    \"city\":     \"{{city}}\",\r\n    \"address\":  \"{{Addr}}\",\r\n    \"bio\":      \"{{BIO}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}{{RegisterEP}}",
          "host": [
            "{{URL}}{{RegisterEP}}"
          ]
        }
      },
      "response": []
    },
