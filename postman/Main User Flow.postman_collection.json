    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let body = pm.response.json();\r",
              "\r",
              "pm.test(\"check status code\", function () {\r",
              "    pm.expect(pm.response.code).to.be.eql(200);\r",
              "    pm.expect(pm.response.status).to.be.eq(\"OK\")\r",
              "});\r",
              "\r",
              "pm.test(\"check response time\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "let expectedSchema = {\r",
              "    message: {\r",
              "        type: \"string\"\r",
              "    },\r",
              "    user: {\r",
              "        type: \"object\",\r",
              "        require: [\"id\",\"name\",\"email\",\"role\",\"status\",\"phone\",\"city\",\"address\",\"bio\"],\r",
              "        properties: {\r",
              "            id: {type: \"number\"},\r",
              "            name: {type: \"string\"},\r",
              "            email: {type: \"string\"},\r",
              "            role: {type: \"string\"},\r",
              "            status: {type: \"string\"},\r",
              "            phone: {type: \"string\"},\r",
              "            city: {type: \"string\"},\r",
              "            address: {type: \"string\"},\r",
              "            bio: {type: \"string\"}\r",
              "        }\r",
              "    }\r",
              "}\r",
              "\r",
              "pm.test(\"check user details\", function () {\r",
              "    pm.response.to.have.jsonSchema(expectedSchema);\r",
              "})\r",
              "\r",
              "pm.test(\"check admin data\", function () {\r",
              "    pm.expect(body.user.name).to.eql(\"Admin User\");\r",
              "    pm.expect(body.user.email).to.eql(\"admin@test.com\");\r",
              "    pm.expect(body.user.role).to.eql(\"admin\");\r",
              "    pm.expect(body.user.status).to.eql(\"active\");\r",
              "    pm.expect(body.user.phone).to.eql(\"01000000000\");\r",
              "    pm.expect(body.user.city).to.eql(\"Alexandria\");\r",
              "    pm.expect(body.user.address).to.eql(\"Admin office\");\r",
              "    pm.expect(body.user.bio).to.eql(\"Main system admin account.\");\r",
              "    pm.expect(body.message).to.eql(\"Login successful\");\r",
              "})\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
